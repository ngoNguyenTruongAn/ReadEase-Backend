# ── App ──
APP_PORT=3000
APP_ENV=development
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=readease
DB_USER=readease_app
DB_PASSWORD=your_password_here

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT (secret must be ≥ 16 characters) ──
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── ML Engine (optional) ──
ML_ENGINE_URL=http://localhost:8000
ML_TIMEOUT_MS=5000

# ── Gemini AI (optional) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

#Load Test And Tracking Test
WS_PORT=3001
WS_URL=ws://localhost:3001/tracking
REDIS_ACTIVE_SESSIONS_KEY=tracking:active
METRICS_ENABLED=true
METRICS_PORT=9090
WS_MAX_PAYLOAD=1048576
REDIS_FLUSH_INTERVAL=5000
REDIS_TRAJECTORY_PREFIX=trajectory
LOAD_TEST_POINTS_PER_BATCH=5
LOAD_TEST_CLIENTS=1000
LOAD_TEST_INTERVAL_MS=100