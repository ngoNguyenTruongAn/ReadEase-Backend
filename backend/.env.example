# ── App ──
APP_PORT=3000
APP_ENV=development
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=readease
DB_USER=readease_app
DB_PASSWORD=your_password_here

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT (secret must be ≥ 16 characters) ──
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Guardian Data API confirmation tokens ──
GUARDIAN_EXPORT_CONFIRMATION_TOKEN=CONFIRM_EXPORT_CHILD_DATA
GUARDIAN_ERASE_CONFIRMATION_TOKEN=CONFIRM_ERASE_CHILD_DATA

# ── ML Engine (optional) ──
ML_ENGINE_URL=http://localhost:8000
ML_TIMEOUT_MS=5000

# ── Segmentation (uses ML_SERVICE_URL) ──
SEGMENTATION_TIMEOUT_MS=5000
# ── Gemini AI (optional) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# ── WebSocket Tracking ─────────────────────────
WS_URL=ws://localhost:3000/tracking
REDIS_ACTIVE_SESSIONS_KEY=tracking:active
# ── WebSocket limits ───────────────────────────
WS_MAX_PAYLOAD=1048576

# ── Redis buffer config ────────────────────────
REDIS_FLUSH_INTERVAL=5000
REDIS_TRAJECTORY_PREFIX=trajectory

# ── Metrics ────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090

# ── Load test config (QA) ──────────────────────
LOAD_TEST_POINTS_PER_BATCH=5
LOAD_TEST_CLIENTS=100
LOAD_TEST_INTERVAL_MS=100