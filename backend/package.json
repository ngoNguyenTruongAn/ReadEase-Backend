{
  "name": "readease-backend",
  "version": "0.1.0",
  "description": "ReadEase Backend — Adaptive reading platform for children with dyslexia",
  "author": "ReadEase Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\"",
    "start": "node src/main.js",
    "start:dev": "nodemon --watch src --ext js --exec \"node src/main.js\"",
    "start:debug": "nodemon --watch src --ext js --exec \"node --inspect src/main.js\"",
    "start:prod": "node src/main.js",
    "lint": "eslint \"{src,test}/**/*.js\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:run": "npx typeorm migration:run -d src/database/data-source.js",
    "migration:revert": "npx typeorm migration:revert -d src/database/data-source.js",
    "migration:generate": "npx typeorm migration:generate -d src/database/data-source.js",
    "test:integration": "node qa/integration/websocket-flow.test.js",
    "test:load": "node qa/load-tests/websocket-tracking.test.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/platform-ws": "^11.1.16",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.16",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io-client": "^4.8.3",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.js$",
    "collectCoverageFrom": [
      "**/*.js",
      "!main.js"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
