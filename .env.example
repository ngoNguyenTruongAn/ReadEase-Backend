# ──────────────────────────────────────────────
# ReadEase — Environment Variables
# Copy to .env and fill in your values
# Variables marked (REQUIRED) will crash the app if missing
# ──────────────────────────────────────────────

# ── Application ────────────────────────────────
APP_PORT=3000
APP_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL Database (REQUIRED) ─────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=readease
DB_USER=readease_app
DB_PASSWORD=devpassword

# ── Redis Cache (REQUIRED) ─────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT Authentication (REQUIRED) ──────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Gemini AI (optional) ──────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── ML Engine ──────────────────────────────────
ML_ENGINE_URL=http://ml-engine:8000
ML_TIMEOUT_MS=5000

# ── Docker Compose (used by docker-compose.yml) ─
POSTGRES_USER=readease_app
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=readease
ML_SERVICE_PORT=8000