# ReadEase Backend Repository - Docker Compose Environment Variables
# Copy this file to .env in ReadEase-Backend when using docker compose.
# Keep real secrets in .env only. Do not commit production values.

# Application
APP_PORT=3000
APP_ENV=development
LOG_LEVEL=debug
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3001

# PostgreSQL database used by docker-compose.yml
POSTGRES_DB=readease
POSTGRES_USER=readease_app
POSTGRES_PASSWORD=devpassword
DB_HOST=postgres
DB_PORT=5432
DB_NAME=readease
DB_USER=readease_app
DB_PASSWORD=devpassword

# Redis cache/buffer
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=
REDIS_PASSWORD=
REDIS_TLS=false

# JWT authentication
# Use a long random string in real environments.
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Guardian data export/erase confirmation tokens
GUARDIAN_EXPORT_CONFIRMATION_TOKEN=CONFIRM_EXPORT_CHILD_DATA
GUARDIAN_ERASE_CONFIRMATION_TOKEN=CONFIRM_ERASE_CHILD_DATA

# ML engine
ML_ENGINE_URL=http://ml-engine:8000
ML_SERVICE_URL=http://ml-engine:8000
ML_TIMEOUT_MS=5000
ML_CLASSIFY_TIMEOUT=3000
ML_SERVICE_PORT=8000
ML_PORT=8000

# Gemini / OpenRouter AI providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Supabase storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=media

# SMTP mail / OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ReadEase <noreply@readease.app>
OTP_TTL_SECONDS=300
OTP_LOCK_SECONDS=900
OTP_COOLDOWN_SEC=60
OTP_MAX_ATTEMPTS=5

# Reading segmentation and lexical cache
SEGMENTATION_TIMEOUT_MS=5000
LEXICAL_CACHE_TTL_SECONDS=86400
LEXICAL_GEMINI_TIMEOUT_MS=5000

# WebSocket tracking
WS_URL=ws://localhost:3000/tracking
WS_MAX_PAYLOAD=1048576
TRACKING_ROLLING_WINDOW_MS=2500
TRACKING_ROLLING_WINDOW_MAX_POINTS=120
TRACKING_ROLLING_WINDOW_MIN_POINTS=8
TRACKING_INTERVENTION_COOLDOWN_MS=6000

# Redis tracking buffer
REDIS_ACTIVE_SESSIONS_KEY=tracking:active
REDIS_FLUSH_INTERVAL=5000
REDIS_TRAJECTORY_PREFIX=trajectory

# Metrics / QA / seed helpers
METRICS_ENABLED=true
METRICS_PORT=9090
RUN_DB_INTEGRATION_TESTS=false
LOAD_TEST_POINTS_PER_BATCH=5
LOAD_TEST_CLIENTS=100
LOAD_TEST_INTERVAL_MS=100
TEST_CONTENT_ID=
TEST_EMAIL=
SEED_CLINICIAN_ID=
