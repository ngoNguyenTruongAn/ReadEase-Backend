# ──────────────────────────────────────────────
# ReadEase — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── Application ────────────────────────────────
APP_PORT=3000
APP_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL Database ────────────────────────
POSTGRES_USER=readease_app
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=readease
DB_HOST=postgres
DB_PORT=5432

# ── Redis Cache ────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT Authentication ─────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Gemini AI ──────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ── ML Engine ──────────────────────────────────
ML_ENGINE_URL=http://ml-engine:8000
ML_SERVICE_PORT=8000
ML_TIMEOUT_MS=5000